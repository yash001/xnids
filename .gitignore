# =====================================================================
# xNIDS Project — .gitignore
# Covers: Python/FastAPI backend, React/Vite frontend, databases,
# trained model caches, OS/editor cruft, and presentation build output.
# =====================================================================

# ---------------------------------------------------------------------
# Backend — Python
# ---------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
backend/.venv/
backend/venv/
backend/env/
.venv/
venv/
ENV/

# Packaging / build
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# Environment variables / secrets
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# ---------------------------------------------------------------------
# Backend — runtime data this project generates itself
# (databases and trained-model caches are created automatically on
# startup — see README Section 4 — and should never be committed)
# ---------------------------------------------------------------------
backend/*.db
backend/*.sqlite
backend/*.sqlite3
*.db
*.sqlite
*.sqlite3

backend/app/trained_models.pkl
**/trained_models.pkl
*.pkl

# Local MySQL dumps, if anyone exports one for debugging
*.sql.gz
*.dump

# ---------------------------------------------------------------------
# Frontend — Node / Vite / React
# ---------------------------------------------------------------------
frontend/node_modules/
node_modules/
frontend/dist/
dist/
frontend/dist-ssr/
frontend/.vite/
.vite/

# npm / yarn / pnpm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Frontend env files (keep the example as a template)
frontend/.env
frontend/.env.*
!frontend/.env.example

# ---------------------------------------------------------------------
# Presentation build artifacts
# (regenerate via docs/build_presentation.js — see docs/README.md;
# only the final presentation.pptx is meant to be tracked)
# ---------------------------------------------------------------------
docs/*.pdf
docs/slide-*.jpg
docs/slide-*.png
slide-*.jpg
slide-*.png

# ---------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------
*.log
logs/
uvicorn.log
vite.log

# ---------------------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------
# OS cruft
# ---------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------------------------------------------------------------------
# Testing / coverage
# ---------------------------------------------------------------------
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
coverage.xml
*.cover

# ---------------------------------------------------------------------
# Type checker / lint caches
# ---------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.eslintcache
backend/app/__init__.py
backend/app/core/__init__.py
backend/app/models/__init__.py
backend/app/routers/__init__.py
docs/build_presentation.js
docs/README.md
